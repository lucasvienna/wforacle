# Canonical site origin used at build time for SEO (canonical URLs, Open Graph
# tags, JSON-LD, sitemap.xml, llms.txt). Must be an absolute origin with no
# trailing slash. Since the site is fully prerendered, this is baked into the
# static output at build time -- there is no live request origin to fall back
# on. Override this for preview/staging builds; when unset, it falls back to
# the production URL (https://wforacle.avyiel.dev).
PUBLIC_SITE_URL=https://wforacle.avyiel.dev
