{
	"name": "wforacle",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && vite build",
		"deploy": "wrangler deploy",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "pnpm test:unit --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"gen": "wrangler types",
		"data:build": "tsx scripts/build-data.ts",
		"lint": "oxlint",
		"lint:check": "wrangler types && svelte-kit sync && oxlint",
		"lint:fix": "wrangler types && svelte-kit sync && oxlint --fix --fix-suggestions",
		"format": "oxfmt . && prettier --write -l \"**/*.svelte\"",
		"format:check": "oxfmt --check . && prettier --check \"**/*.svelte\""
	},
	"dependencies": {
		"idb": "^8.0.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"@types/node": "^26.1.1",
		"@wfcd/items": "^1.1275.5",
		"fake-indexeddb": "^6.2.5",
		"jsdom": "^29.1.1",
		"mdsvex": "^0.12.7",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"playwright": "^1.60.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vite": "^8.1.4",
		"vitest": "^4.1.10",
		"warframe-worldstate-data": "^3.16.3",
		"wrangler": "^4.110.0"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@11.11.0"
}
